{
  "IsEncrypted": false,
  "Values": {
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",
    "FUNCTIONS_EXTENSION_VERSION": "~4",

    "AzureWebJobsStorage": "UseDevelopmentStorage=true",

    "APPLICATIONINSIGHTS_CONNECTION_STRING": "",

    "ServiceBusConnection__fullyQualifiedNamespace": "<your-sb-namespace>.servicebus.windows.net",

    "ServiceBusOrdersQueueName": "orders",
    "ServiceBusErpDeliveryQueueName": "erp-delivery",

    "ErpEndpointUrl": "http://localhost:5001/api/erp/deliveries",
    "NotificationWebhookUrl": "https://hooks.example.com/replace-with-your-webhook",

    "ClaimCheckContainerName": "claim-check-payloads",
    "IdempotencyContainerName": "idempotency-store",

    "ClaimCheckThresholdBytes": "65536"
  }
}
